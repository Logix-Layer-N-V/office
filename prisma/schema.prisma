// Logix Layer N.V. — Finance Department Schema
// Database: PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Organization ───────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String   @default("Logix Layer N.V.")
  website   String?
  logo      String?
  address   String?
  phone     String?
  email     String?
  taxId     String?  @map("tax_id")
  currency  String   @default("USD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     Member[]
  clients     Client[]
  items       Item[]
  proposals   Proposal[]
  estimates   Estimate[]
  invoices    Invoice[]
  payments    Payment[]
  bankAccounts BankAccount[]
  expenses    Expense[]
  credits     Credit[]
  loans       Loan[]
  ledgerEntries LedgerEntry[]
  accounts    ChartOfAccount[]

  @@map("organizations")
}

model Member {
  id             String       @id @default(cuid())
  clerkUserId    String       @unique @map("clerk_user_id")
  email          String
  name           String
  role           MemberRole   @default(MEMBER)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Clients (CRM) ─────────────────────────────

model Client {
  id             String       @id @default(cuid())
  name           String
  email          String
  phone          String?
  company        String?
  address        String?
  taxId          String?      @map("tax_id")
  currency       String       @default("USD")
  status         ClientStatus @default(ACTIVE)
  notes          String?
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  proposals  Proposal[]
  estimates  Estimate[]
  invoices   Invoice[]
  payments   Payment[]

  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  LEAD
  ARCHIVED
}

// ─── Items Catalog ─────────────────────────────

model Item {
  id             String       @id @default(cuid())
  name           String
  type           ItemType
  description    String?
  unit           String       @default("hour")
  rate           Decimal      @default(65) @db.Decimal(10, 2)
  isActive       Boolean      @default(true) @map("is_active")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("items")
}

enum ItemType {
  SERVICE
  PRODUCT
  API_COST
  AI_TOKEN
}

// ─── Proposals ─────────────────────────────────

model Proposal {
  id             String         @id @default(cuid())
  number         String         @unique
  title          String
  description    String?
  status         ProposalStatus @default(DRAFT)
  clientId       String         @map("client_id")
  client         Client         @relation(fields: [clientId], references: [id])
  organizationId String         @map("organization_id")
  organization   Organization   @relation(fields: [organizationId], references: [id])

  items          ProposalItem[]
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  taxRate        Decimal        @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total          Decimal        @default(0) @db.Decimal(12, 2)

  validUntil     DateTime?      @map("valid_until")
  approvedAt     DateTime?      @map("approved_at")
  sentAt         DateTime?      @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("proposals")
}

model ProposalItem {
  id          String   @id @default(cuid())
  proposalId  String   @map("proposal_id")
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  description String
  hours       Decimal  @default(0) @db.Decimal(8, 2)
  rate        Decimal  @default(65) @db.Decimal(10, 2)
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")

  @@map("proposal_items")
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

// ─── Estimates ─────────────────────────────────

model Estimate {
  id             String         @id @default(cuid())
  number         String         @unique
  title          String
  description    String?
  status         EstimateStatus @default(DRAFT)
  clientId       String         @map("client_id")
  client         Client         @relation(fields: [clientId], references: [id])
  organizationId String         @map("organization_id")
  organization   Organization   @relation(fields: [organizationId], references: [id])

  items          EstimateItem[]
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  taxRate        Decimal        @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total          Decimal        @default(0) @db.Decimal(12, 2)

  validUntil     DateTime?      @map("valid_until")
  convertedToInvoiceId String?  @unique @map("converted_to_invoice_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("estimates")
}

model EstimateItem {
  id          String   @id @default(cuid())
  estimateId  String   @map("estimate_id")
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  description String
  hours       Decimal  @default(0) @db.Decimal(8, 2)
  rate        Decimal  @default(65) @db.Decimal(10, 2)
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")

  @@map("estimate_items")
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
}

// ─── Invoices ──────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  title          String
  description    String?
  status         InvoiceStatus @default(DRAFT)
  clientId       String        @map("client_id")
  client         Client        @relation(fields: [clientId], references: [id])
  organizationId String        @map("organization_id")
  organization   Organization  @relation(fields: [organizationId], references: [id])

  items          InvoiceItem[]
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  taxRate        Decimal       @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountDue      Decimal       @default(0) @map("amount_due") @db.Decimal(12, 2)

  issueDate      DateTime      @default(now()) @map("issue_date")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  payments       Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  hours       Decimal @default(0) @db.Decimal(8, 2)
  rate        Decimal @default(65) @db.Decimal(10, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

// ─── Payments & Transactions ───────────────────

model Payment {
  id             String        @id @default(cuid())
  number         String        @unique
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  reference      String?
  notes          String?
  invoiceId      String?       @map("invoice_id")
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  clientId       String        @map("client_id")
  client         Client        @relation(fields: [clientId], references: [id])
  bankAccountId  String?       @map("bank_account_id")
  bankAccount    BankAccount?  @relation(fields: [bankAccountId], references: [id])
  organizationId String        @map("organization_id")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  receivedAt     DateTime      @default(now()) @map("received_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("payments")
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  PAYPAL
  CRYPTO
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Bank Accounts ─────────────────────────────

model BankAccount {
  id             String         @id @default(cuid())
  name           String
  bankName       String         @map("bank_name")
  accountNumber  String         @map("account_number")
  routingNumber  String?        @map("routing_number")
  iban           String?
  swift          String?
  type           BankAccountType @default(CHECKING)
  currency       String         @default("USD")
  balance        Decimal        @default(0) @db.Decimal(14, 2)
  isDefault      Boolean        @default(false) @map("is_default")
  organizationId String         @map("organization_id")
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  payments       Payment[]
  transactions   Transaction[]

  @@map("bank_accounts")
}

model Transaction {
  id            String          @id @default(cuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  description   String
  reference     String?
  bankAccountId String          @map("bank_account_id")
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  date          DateTime        @default(now())
  createdAt     DateTime        @default(now()) @map("created_at")

  @@map("transactions")
}

enum BankAccountType {
  CHECKING
  SAVINGS
  CASH
  CRYPTO
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  FEE
}

// ─── Credits ───────────────────────────────────

model Credit {
  id             String       @id @default(cuid())
  number         String       @unique
  description    String
  amount         Decimal      @db.Decimal(12, 2)
  remaining      Decimal      @db.Decimal(12, 2)
  status         CreditStatus @default(ACTIVE)
  reason         String?
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  issuedAt       DateTime     @default(now()) @map("issued_at")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("credits")
}

enum CreditStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

// ─── Expenses ──────────────────────────────────

model Expense {
  id             String          @id @default(cuid())
  description    String
  amount         Decimal         @db.Decimal(12, 2)
  category       ExpenseCategory
  vendor         String?
  receipt        String?
  notes          String?
  status         ExpenseStatus   @default(PENDING)
  organizationId String          @map("organization_id")
  organization   Organization    @relation(fields: [organizationId], references: [id])
  date           DateTime        @default(now())
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("expenses")
}

enum ExpenseCategory {
  SOFTWARE
  HARDWARE
  OFFICE
  TRAVEL
  MARKETING
  SALARY
  CONTRACTOR
  UTILITIES
  INSURANCE
  TAX
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ─── Loans ─────────────────────────────────────

model Loan {
  id             String     @id @default(cuid())
  name           String
  lender         String
  amount         Decimal    @db.Decimal(14, 2)
  remainingBalance Decimal  @map("remaining_balance") @db.Decimal(14, 2)
  interestRate   Decimal    @map("interest_rate") @db.Decimal(5, 2)
  monthlyPayment Decimal    @map("monthly_payment") @db.Decimal(12, 2)
  startDate      DateTime   @map("start_date")
  endDate        DateTime   @map("end_date")
  status         LoanStatus @default(ACTIVE)
  notes          String?
  organizationId String     @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@map("loans")
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

// ─── General Ledger ────────────────────────────

model ChartOfAccount {
  id             String      @id @default(cuid())
  code           String
  name           String
  type           AccountType
  subtype        String?
  description    String?
  isActive       Boolean     @default(true) @map("is_active")
  organizationId String      @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  entries        LedgerEntry[]

  @@unique([organizationId, code])
  @@map("chart_of_accounts")
}

model LedgerEntry {
  id             String       @id @default(cuid())
  date           DateTime     @default(now())
  description    String
  debit          Decimal      @default(0) @db.Decimal(14, 2)
  credit         Decimal      @default(0) @db.Decimal(14, 2)
  accountId      String       @map("account_id")
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  reference      String?
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("ledger_entries")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}
